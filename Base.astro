---
// Base layout — global styles + fonts. Mirrors index.html <head>.
const { title = 'Anamorphick — Photographic Studio', description = 'A photographic studio surveying the vernacular American block, one numbered series at a time. Washington, DC.' } = Astro.props;
import '../styles/anamorphick.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/assets/mark-anamorphick.svg" />
  <script is:inline>(function(){try{var t=localStorage.getItem('anamorphick-theme');if(t==='dark')document.documentElement.setAttribute('data-theme','dark');}catch(e){}})();</script>
</head>
<body>
  <slot />
</body>
</html>
