---
// Newsletter band → Ghost members. Submit handled by anamorphick.js (#newsForm).
// For real signup, point the form action at Ghost's members API or embed Ghost Portal.
import SignupBand from './SignupBand.astro';
const { image = '/assets/strange-light/06-interior-dusk.jpg' } = Astro.props;
---
<SignupBand
  id="news"
  eyebrow="The Dispatch"
  headline="A New Survey, In Your Inbox"
  body="Each survey ships with a short letter — what I was looking at, what I got wrong, and the one frame that almost didn't make it. No more than once a month. Free."
  buttonText="Subscribe"
  note="Unsubscribe anytime. A member tier with print discounts is coming."
  ok="Thank you — check your inbox to confirm. The next survey is already underway."
  image={image}
  imageAlt="A dim interior glowing amber at dusk"
/>
